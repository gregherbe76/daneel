# Copy this file to `.env` and adjust values as needed.
# Empty values are fine for a first run — docker-compose.yml provides safe defaults
# matching the in-stack Postgres service.

# Postgres connection string used by the API server and the seed script.
# Default in docker-compose.yml: postgresql://daneel:daneel@db:5432/daneel
DATABASE_URL=

# Secret for signing sessions / cookies.
# Default in docker-compose.yml: dev-session-secret-change-me
SESSION_SECRET=

# Optional — only needed if you wire up Anthropic-backed providers.
ANTHROPIC_API_KEY=

# Optional — only needed if you use the Native OpenAI workflow providers.
OPENAI_API_KEY=
