# syntax=docker/dockerfile:1.6
# Build context: repo root.

FROM node:20-bookworm-slim AS builder
ENV PNPM_HOME=/root/.local/share/pnpm
ENV PATH="$PNPM_HOME:$PATH"
# Pre-provision pnpm so the build doesn't depend on corepack fetching it at
# install time (matches root package.json `packageManager` field).
RUN corepack enable && corepack prepare pnpm@10.26.1 --activate
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
# Build args picked up by Vite at build time.
ENV PORT=5173
ENV BASE_PATH=/
ENV VITE_APP_TEMPLATE=hiringai
RUN pnpm --filter @workspace/recruiting-os run build

FROM nginx:1.27-alpine AS runtime
COPY artifacts/recruiting-os/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/artifacts/recruiting-os/dist/public /usr/share/nginx/html
EXPOSE 5173
HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=10 \
  CMD wget -q -O - http://localhost:5173/ >/dev/null || exit 1
CMD ["nginx", "-g", "daemon off;"]
